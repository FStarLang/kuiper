#!/bin/bash

usage () {
	echo "usage: $0 [<file>]" >&2
	echo "This script will output source-able commands into the file that you" >&2
	echo "should use to set up your environment. You still have to pass the" >&2
	echo "relevant -D flags to nvcc. If no <file> is passed, stdout is used." >&2
	exit 1
}

if [ $# -eq 0 ]; then
  out=/dev/stdout
  repeat=false
elif [ $# -eq 1 ]; then
  out=$1
  repeat=true
else
  usage
fi

# A really basic configure script.

check_nvcc () {
  if ! command -v nvcc >/dev/null 2>&1 ; then
    echo "# NVCC not found in PATH, configuring to stop after code generation."
    KUIPER_HAVE_NVCC=0
    return
  fi

  f=$(mktemp --suffix .cu)
  cat >$f <<EOF
  #include <cuda.h>
  __global__
  void f() {
    return;
  }
  void g () {
    f<<<1,1>>>();
  }
EOF

  #177: variable "f" was declared but never referenced
  echo "# Testing nvcc compilation..."
  if ! nvcc -arch=native -diag-suppress 177 -c $f -o /dev/null ; then
    echo "# NVCC test file failed to build, configuring to stop after code generation."
    KUIPER_HAVE_NVCC=0
  else
    echo "# NVCC ok"
    KUIPER_HAVE_NVCC=1
  fi
  rm -f "$f"
}

check_tensor_cores () {
  # Do we have tensor cores?
  f=$(mktemp --suffix .cu)
  cat >$f <<EOF
  #include <mma.h>
  using namespace nvcuda;
  void f() {
    wmma::fragment<wmma::matrix_a, 16, 16, 16, half, wmma::row_major> f;
  }
EOF

  #177: variable "f" was declared but never referenced
  echo "# Checking for tensor cores in nvcc..."
  if ! nvcc -arch=native -diag-suppress 177 -c $f -o /dev/null ; then
    echo "# Tensor core test file failed to build, assuming no tensor cores."
    KUIPER_CFG_TENSORCORES=0
  else
    echo "# The test built, assuming we have tensor cores."
    KUIPER_CFG_TENSORCORES=1
  fi
  rm -f "$f"
}

check_nvcc
if [ "$KUIPER_HAVE_NVCC" -eq 1 ]; then
  check_tensor_cores
fi

# Export whatever variables are needed.
vv () {
  for v; do
    if [ -v "$v" ]; then
      echo "export ${v}=${!v}" >> $out
      if $repeat; then
        echo "export ${v}=${!v}"
      fi
    fi
  done
}

if [ "$out" != /dev/stdout ]; then
  rm -f "$out"
fi
vv KUIPER_HAVE_NVCC KUIPER_CFG_TENSORCORES
