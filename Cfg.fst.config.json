{
  "fstar_exe": "FStar/bin/fstar.exe",
  "options": [
    "--query_cache",
    "--load_cmxs", "pulse",
    "--warn_error", "-249",
    "--already_cached", "Pulse.Lib.*",
    "--ext", "__unrefine",
    "--ext", "context_pruning",
    "--ext", "no_krml_private",
    "--ext", "krml_inline_all"
  ],
  "include_dirs": [
    ".cache",
    "pulse",
    "src"
  ]
}
