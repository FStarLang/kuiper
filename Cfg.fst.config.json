{
  "fstar_exe": "FStar/bin/fstar.exe",
  "options": [
    "--query_cache",
    "--load_cmxs", "pulse",
    "--warn_error", "-249",
    "--already_cached", "Pulse.Lib.*",
    "--ext", "__unrefine",
    "--ext", "context_pruning",
    "--ext", "no_krml_private",
    "--ext", "extraction_inline_all"
  ],
  "include_dirs": [
    ".cache",
    "pulse/lib/pulse",
    "pulse/lib/pulse/core",
    "pulse/lib/pulse/lib",
    "pulse/lib/pulse/lib/class",
    "src/lib",
    "src/examples",
    "src/examples/matmul",
    "src/examples/matmul-opt"
  ]
}
