ghost
fn forevery_unfactor'
  (n : nat)
  (d1 : nat) (d2 : nat { n == d1 * d2 })
  (p : natlt d1 -> natlt d2 -> slprop)
  requires
    forall+ (i1:natlt d1) (i2:natlt d2). p i1 i2
  ensures
    forall+ (i:natlt n). p (i/d2) (i%d2)
{
  rewrite
    forall+ (i1: natlt d1) (i2: natlt d2). p i1 i2
  as
    forall+ (i1: natlt d1) (i2: natlt d2).
      p ((i1 * d2 + i2) / d2) ((i1 * d2 + i2) % d2);
  forevery_unfactor n d1 d2 (fun i -> p (i/d2) (i%d2));
}

ghost
fn forevery_map_2
  (#a:Type0)
  (#b:Type0)
  (p1 p2 : a -> b -> slprop)
  (f : (x:a -> y:b -> stt_ghost unit emp_inames (p1 x y) (fun _ -> p2 x y)))
  requires
    forall+ (x:a) (y:b). p1 x y
  ensures
    forall+ (x:a) (y:b). p2 x y
{
  forevery_map #a
    (fun x -> forevery b (fun y -> p1 x y))
    (fun x -> forevery b (fun y -> p2 x y))
    (fun x -> forevery_map (fun y -> p1 x y)
                          (fun y -> p2 x y)
                          (f x));
}

ghost
fn forevery_map'
  (#a:Type0)
  (#b:Type0 { a == b })
  (p1 : a -> slprop)
  (p2 : b -> slprop)
  (f : (x:a -> y:b { x === y } -> stt_ghost unit emp_inames (p1 x) (fun _ -> p2 y)))
  requires
    forall+ (x:a). p1 x
  ensures
    forall+ (x:b). p2 x
{
  rewrite each a as b;
  forevery_map #b p1 p2 fn x { f x x };
}

ghost
fn forevery_zip_2
  (#a:Type0) {| enumerable a |}
  (#b:Type0) {| enumerable b |}
  (p1 p2 : a -> b -> slprop)
  requires
    (forall+ (x:a) (y:b). p1 x y) **
    (forall+ (x:a) (y:b). p2 x y)
  ensures
    forall+ (x:a) (y:b). p1 x y ** p2 x y
{
  forevery_zip (fun (x:a) -> forall+ (y:b). p1 x y) _;
  forevery_map _ _ (fun x -> forevery_zip (fun (y:b) -> p1 x y) _);
}

ghost
fn forevery_unzip_2
  (#a:Type0) {| enumerable a |}
  (#b:Type0) {| enumerable b |}
  (p1 p2 : a -> b -> slprop)
  requires
    forall+ (x:a) (y:b). p1 x y ** p2 x y
  ensures
    (forall+ (x:a) (y:b). p1 x y) **
    (forall+ (x:a) (y:b). p2 x y)
{
  forevery_map _ _ (fun x -> forevery_unzip (fun (y:b) -> p1 x y) _);
  forevery_unzip (fun (x:a) -> forall+ (y:b). p1 x y) _;
}

ghost
fn forevery_pad
  (n1 : nat)
  (n2 : nat{n1 <= n2})
  (p : natlt n1 -> slprop)
  requires
    forall+ (i : natlt n1). p i
  ensures
    forall+ (i : natlt n2). pad_f n2 p i
{
  forevery_ext #(natlt n1) p (fun (i: natlt n1) -> pad_f n2 p (natlt_coerce i));
  forevery_natlt_extend n2 (fun (i: natlt n1) -> pad_f n2 p (natlt_coerce i));
  forevery_fill (fun (i: natlt n2) -> pad_f n2 p i)
    (fun i -> i >= n1) fn i { rewrite emp as pad_f #n1 n2 p i };
  forevery_unrefine (fun (i: natlt n2) -> pad_f n2 p i);
}

ghost
fn forevery_unpad
  (n1 : nat)
  (n2 : nat{n1 <= n2})
  (p : natlt n1 -> slprop)
  requires
    forall+ (i : natlt n2). pad_f n2 p i
  ensures
    forall+ (i : natlt n1). p i
{
  forevery_refine_split (fun (i: natlt n2) -> pad_f n2 p i) (fun i -> i < n1);
  drop_ (forall+ (i: natlt n2 { ~(i < n1) }). pad_f n2 p i);
  forevery_natlt_restrict n2 (fun (i: natlt n1) -> pad_f n2 p (natlt_coerce i));
  forevery_ext #(natlt n1) (fun (i: natlt n1) -> pad_f n2 p (natlt_coerce i)) p;
}

ghost
fn forevery_extract
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z ** (p z @==> forall+ (x:a). p x)
{
  forevery_remove p z;
  intro (p z @==> forall+ (x:a). p x) #(forall+ (x:a{x =!= z}). p x) fn _ {
    forevery_insert p z;
    forevery_unrefine p;
  }
}

// FIXME: Type-class inference fails inside Pulse?!?
let forevery_extract'_aux #a (z:a) (p: a->slprop) =
  intro (forall* (p' : a -> slprop).
      p' z ** pure (forall (x:a{x =!= z}). p' x == p x)
        @==> (forall+ (x:a). p' x))
    #(forall+ (x:a{x =!= z}). p x)

ghost
fn forevery_extract'
  (#a:Type0)
  (z : a)
  (p  : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z **
      (forall* (p' : a -> slprop).
        p' z ** pure (forall (x:a{x =!= z}). p' x == p x)
          @==> (forall+ (x:a). p' x))
{
  forevery_remove p z;
  forevery_extract'_aux z p fn _ p' {
    forevery_map #(x:a{x =!= z}) p p'
      fn x { rewrite p x as p' x };
    forevery_insert p' z;
    forevery_unrefine p';
  };
}

ghost
fn forevery_extract_2
  (#a:Type0)
  (#b:Type0)
  (z : a) (w : b)
  (p : a -> b -> slprop)
  requires
    forall+ (x:a) (y:b). p x y
  ensures
    p z w ** (p z w @==> forall+ (x:a) (y:b). p x y)
{
  forevery_flatten p;
  forevery_remove (fun (xy: a & b) -> p xy._1 xy._2) (z, w);
  with z' w'. rewrite p z' w' as p z w;
  intro (p z w @==> forall+ (x:a) (y:b). p x y)
    #(forall+ (xy: a&b { xy =!= (z,w) }). p xy._1 xy._2)
    fn _ {
      rewrite p z w as p (z,w)._1 (z,w)._2;
      forevery_insert (fun (xy: a&b) -> p xy._1 xy._2) (z, w);
      forevery_unrefine (fun (xy: a&b) -> p xy._1 xy._2);
      forevery_unflatten p;
    };
}

ghost
fn forevery_extract_if
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z **
    (forall+ (x:a). unless (x == z) (p x))
{
  forevery_remove p z;
  forevery_unrefine_pred p (fun x -> x =!= z);
  forevery_ext (fun x -> when_ (x =!= z) (p x)) (fun x -> unless (x == z) (p x));
}

ghost
fn forevery_extract_if_eqtype
  (#a:eqtype)
  (z : a)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z **
    (forall+ (x:a).
      if x = z then emp else p x)
{
  forevery_extract_if z p;
  rewrite
    (forall+ (x:a).
      if t2b (x == z) then emp else p x)
  as
    (forall+ (x:a).
      if x = z then emp else p x);
}

ghost
fn forevery_unextract_if
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    p z **
    (forall+ (x:a). unless (x == z) (p x))
  ensures
    forall+ (x:a). p x
{
  forevery_remove (fun x -> unless (x == z) (p x)) z;
  rewrite unless True (p z) as emp;
  forevery_ext
    (fun (x: a{x =!= z}) -> unless (x == z) (p x))
    (fun (x: a{x =!= z}) -> p x);
  forevery_insert p z;
  forevery_unrefine p;
}

ghost
fn forevery_unextract_if_eqtype
  (#a:eqtype)
  (z : a)
  (p : a -> slprop)
  requires
    p z **
    (forall+ (x:a).
      if x = z then emp else p x)
  ensures
    forall+ (x:a). p x
{
  rewrite
    (forall+ (x:a).
      if x = z then emp else p x)
  as
    (forall+ (x:a).
      if t2b (x == z) then emp else p x);
  forevery_unextract_if z p;
}

ghost
fn forevery_extract_if_2
  (#a:Type0)
  (#b:Type0)
  (z : a) (w : b)
  (p : a -> b -> slprop)
  requires
    forall+ (x:a) (y:b). p x y
  ensures
    p z w **
    (forall+ (x:a) (y:b).
      unless ((x, y) == (z, w)) (p x y))
{
  forevery_flatten #a #b _;
  forevery_extract_if (z, w) _;
  forevery_unflatten' #a #b _;
  rewrite p (z,w)._1 (z,w)._2 as p z w;
  with q. rewrite
    (forall+ (x:a) (y:b). q x y)
  as
    (forall+ (x:a) (y:b).
      unless ((x, y) == (z, w)) (p x y));
}

ghost
fn forevery_boolean_split
  (#a:Type0)
  (b : a -> bool)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    (forall+ (x:a). if b x then emp else p x) **
    (forall+ (x:a). if b x then p x else emp)
{
  forevery_refine_split p (fun x -> b x);
  forevery_unrefine_pred p (fun x -> b x);
  forevery_unrefine_pred p (fun x -> ~(b x));
  forevery_ext (fun x -> when_ (~(b x)) (p x)) (fun x -> if b x then emp else p x);
  forevery_ext (fun x -> when_ (b x) (p x)) (fun x -> if b x then p x else emp);
}

ghost
fn forevery_boolean_join
  (#a:Type0)
  (b : a -> bool)
  (p1 p2 : a -> slprop)
  requires
    (forall+ (x:a). if b x then p1 x else emp) **
    (forall+ (x:a). if b x then emp else p2 x)
  ensures
    (forall+ (x:a). if b x then p1 x else p2 x)
{
  forevery_ext (fun x -> if b x then p1 x else emp) (fun x -> when_ (b x) (p1 x));
  forevery_refine_pred p1 (fun x -> b x);
  forevery_ext (fun x -> if b x then emp else p2 x) (fun x -> when_ (~(b x)) (p2 x));
  forevery_refine_pred p2 (fun x -> ~(b x));
  forevery_ext #(x:a{ b x }) p1 (fun x -> if b x then p1 x else p2 x);
  forevery_ext #(x:a{ ~(b x) }) p2 (fun x -> if b x then p1 x else p2 x);
  forevery_refine_join (fun x -> if b x then p1 x else p2 x) (fun x -> b x) (fun x -> ~(b x));
  forevery_unrefine _;
}

ghost
fn forevery_boolean_equal_sides
  (#a:Type0)
  (b : a -> bool)
  (p : a -> slprop)
  requires
    (forall+ (x:a). if b x then p x else p x)
  ensures
    (forall+ (x:a). p x)
{
  forevery_ext (fun x -> if b x then p x else p x) p;
}

ghost
fn forevery_intro_if
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    p z
  ensures
    (forall+ (x:a). when_ (x == z) (p x))
{
  forevery_singleton_intro' #(x:a { x == z }) p z;
  forevery_unrefine_pred p _;
}

let bij_either_inl a b : ((x: either a b { Inl? x }) =~ a) =
  mk_bijection #(x: either a b { Inl? x }) Inl?.v (fun x -> Inl x) ez ez

let bij_either_inr a b : ((x: either a b { ~(Inl? x) }) =~ b) =
  mk_bijection #(x: either a b { ~(Inl? x) }) (fun x -> Inr?.v x) (fun x -> Inr x) ez ez

ghost
fn forevery_split_either
  (#a #b : Type0)
  (p : either a b -> slprop)
  requires
    forall+ (x:either a b). p x
  ensures
    (forall+ (x:a). p (Inl x)) **
    (forall+ (x:b). p (Inr x))
{
  forevery_refine_split p (fun x -> Inl? x);
  forevery_iso (bij_either_inl a b) p;
  forevery_ext (fun x -> p ((bij_either_inl a b).gg x)) (fun x -> p (Inl x));
  forevery_iso (bij_either_inr a b) p;
  forevery_ext (fun x -> p ((bij_either_inr a b).gg x)) (fun x -> p (Inr x));
}

ghost
fn forevery_join_either
  (#a #b : Type0)
  (p : either a b -> slprop)
  requires
    (forall+ (x:a). p (Inl x)) **
    (forall+ (x:b). p (Inr x))
  ensures
    forall+ (x:either a b). p x
{
  forevery_ext (fun x -> p (Inl x)) (fun x -> p ((bij_either_inl a b).gg x));
  forevery_ext (fun x -> p (Inr x)) (fun x -> p ((bij_either_inr a b).gg x));
  forevery_iso_back (bij_either_inl a b) p;
  forevery_iso_back (bij_either_inr a b) p;
  forevery_refine_join p (fun x -> Inl? x) (fun x -> ~(Inl? x));
  forevery_unrefine p;
}
