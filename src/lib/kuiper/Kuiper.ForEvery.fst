let singleton_lemma (#a:Type) {| d : enumerable a |} (_:squash (cardinal a #d == 1))
: Lemma (forall (y:a). of_nat 0 == y)
= introduce forall (y:a). of_nat 0 == y
  with assert (d.bij.ff y == 0)

